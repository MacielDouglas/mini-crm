generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH (better-auth schema obrigatório)
// ─────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Auth relations (better-auth)
  sessions      Session[]
  accounts      Account[]

  // CRM relations
  organizationMembers OrganizationMember[]
  assignedLeads       Lead[]               @relation("AssignedTo")
  createdLeads        Lead[]               @relation("CreatedBy")
  interactions        Interaction[]
  aiUsageLogs         AiUsageLog[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  idToken              String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ─────────────────────────────────────────
// ORGANIZAÇÃO (multi-tenant)
// ─────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     OrganizationMember[]
  leads       Lead[]
  customers   Customer[]
  pipeline    PipelineStage[]
  tags        Tag[]
  aiUsageLogs AiUsageLog[]

  @@map("organizations")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(MEMBER)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

// ─────────────────────────────────────────
// PIPELINE
// ─────────────────────────────────────────

model PipelineStage {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String   @default("#6366f1")
  position       Int
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@unique([organizationId, position])
  @@map("pipeline_stages")
}

// ─────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_OUTREACH
  SOCIAL_MEDIA
  EVENT
  PAID_AD
  OTHER
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  stageId        String
  assignedToId   String?
  createdById    String

  // Dados básicos
  name           String
  email          String?
  phone          String?
  company        String?
  jobTitle       String?
  website        String?

  // Pipeline
  status         LeadStatus @default(NEW)
  source         LeadSource @default(OTHER)
  value          Decimal?   @db.Decimal(12, 2)  // valor estimado do negócio

  // IA
  aiScore        Int?       // 0-100 gerado pela Gemini
  aiScoreReason  String?    // justificativa do score
  aiNextAction   String?    // próxima ação sugerida pela IA
  aiScoredAt     DateTime?

  // Controle
  lastContactAt  DateTime?
  expectedCloseAt DateTime?
  closedAt       DateTime?
  notes          String?    @db.Text

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relações
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage          PipelineStage @relation(fields: [stageId], references: [id])
  assignedTo     User?         @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy      User          @relation("CreatedBy", fields: [createdById], references: [id])
  interactions   Interaction[]
  tags           LeadTag[]
  customer       Customer?

  // Full-text search
  @@index([organizationId, status])
  @@index([organizationId, stageId])
  @@index([assignedToId])
  @@index([email])
  @@map("leads")
}

// ─────────────────────────────────────────
// CUSTOMERS (lead que virou cliente)
// ─────────────────────────────────────────

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String   @unique
  name           String
  email          String?
  phone          String?
  company        String?
  totalRevenue   Decimal? @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id])
  interactions Interaction[]

  @@index([organizationId])
  @@map("customers")
}

// ─────────────────────────────────────────
// INTERAÇÕES (timeline do lead/cliente)
// ─────────────────────────────────────────

enum InteractionType {
  NOTE
  EMAIL
  CALL
  MEETING
  TASK
  STATUS_CHANGE
  STAGE_CHANGE
  AI_INSIGHT
}

model Interaction {
  id         String          @id @default(cuid())
  leadId     String?
  customerId String?
  userId     String
  type       InteractionType
  title      String
  content    String?         @db.Text
  metadata   Json?           // dados extras (ex: duração de call, assunto do email)
  occurredAt DateTime        @default(now())
  createdAt  DateTime        @default(now())

  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])

  @@index([leadId, occurredAt])
  @@index([customerId, occurredAt])
  @@map("interactions")
}

// ─────────────────────────────────────────
// TAGS
// ─────────────────────────────────────────

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String   @default("#6366f1")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        LeadTag[]

  @@unique([organizationId, name])
  @@map("tags")
}

model LeadTag {
  leadId    String
  tagId     String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("lead_tags")
}

// ─────────────────────────────────────────
// AI USAGE LOG (controle de uso da Gemini)
// ─────────────────────────────────────────

enum AiAction {
  LEAD_SCORE
  NEXT_ACTION
  CUSTOMER_BRIEF
  PIPELINE_ANALYSIS
}

model AiUsageLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  action         AiAction
  inputTokens    Int
  outputTokens   Int
  durationMs     Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@map("ai_usage_logs")
}